# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: .env.local should NOT be committed to version control

# Supabase Project URL (from https://app.supabase.com/projects > Settings > API)
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (from Settings > API > Project API keys [anon public])
# This key is safe to expose in the frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (from Settings > API > Project API keys [service_role])
# ⚠️ WARNING: Keep this PRIVATE - Never expose this in the frontend!
# Only use on the backend for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# n8n Webhook Configuration (generated when n8n automation is set up)
# This will be the endpoint that receives job posting updates from n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.ngrok.io/webhook/internship-radar

# Discord Configuration (for bot/webhook integrations)
# This can be either a bot token for Discord API calls or a webhook URL
DISCORD_BOT_TOKEN=your-discord-bot-token-here
